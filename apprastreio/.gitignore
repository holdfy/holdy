# =============================================================================
# LogisticaHoldFy — apprastreio/ (Flutter app + backend Rust)
# =============================================================================

# --- Ambiente (nunca commitar) ---
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# --- Rust (backend) ---
backend/target/
backend/**/*.rs.bk

# --- Flutter / Dart (app) ---
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.pub-cache/
app/.pub/
app/build/
app/coverage/

# --- Android ---
app/android/local.properties
app/android/.gradle/
app/android/captures/
app/android/.cxx/
app/android/**/GeneratedPluginRegistrant.java
app/android/**/*.iml
app/android/gradlew
app/android/gradlew.bat
app/android/gradle/wrapper/gradle-wrapper.jar

# --- iOS / macOS (gerados localmente) ---
app/ios/Flutter/ephemeral/
app/ios/Flutter/Generated.xcconfig
app/ios/Flutter/flutter_export_environment.sh
app/ios/Pods/
app/ios/.symlinks/
app/ios/**/DerivedData/
app/macos/Flutter/ephemeral/
app/macos/Flutter/GeneratedPluginRegistrant.swift

# --- Linux / Windows (artefactos de build) ---
app/linux/flutter/ephemeral/
app/windows/flutter/ephemeral/

# --- Web (se activar plataforma web) ---
app/web/.dart_tool/

# --- IDE / editor ---
.idea/
.vscode/
*.iml
*.ipr
*.iws

# --- Logs e temporários ---
*.log
*.tmp
*.swp
.DS_Store

# --- README gerado pelo flutter create (documentação está em apprastreio/README.md) ---
app/README.md

# --- Binários de release ---
**/*.apk
**/*.aab
**/*.ipa
