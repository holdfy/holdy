# =============================================================================
# Workspace `money/` — ÚNICO ficheiro modelo de variáveis (versionado no Git).
#
# Fluxo:
#   cp .env.example .env && edite segredos (ou use ./setup-env.sh que cria `.env` + symlinks nos crates)
#
# Carregado por: Docker Compose, runinfra.sh, runapp.sh, binários (symlinks apicash/.env e gatebox/.../.env).
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
APP_ENV=development
API_PORT=3000
ADMIN_PORT=3001
RUST_LOG=info,apicash_core=info,apicash_admin_backend=info,tower_http=info,apicash_whatsapp=info,whatsapp_rust=info
# Saída JSON estruturada (agregadores / produção)
APICASH_LOG_FORMAT=
RUST_BACKTRACE=1

# Host para URLs de serviços locais (Postgres, Redis, NATS, Gatebox, APICash).
# Padrão: 127.0.0.1 (só esta máquina). Para expor na LAN, troque para o IP da máquina (ex: 192.168.1.100)
# e execute ./setup-env.sh — ele sincroniza automaticamente todas as URLs abaixo.
MONEY_LAN_HOST=127.0.0.1

# Site público (holdy/site) — runapp.sh: npm/bun run dev; defeito porta 5173 (evita Pulsar :8080)
# SITE_DIR=/home/you/git/holdy/site
# SITE_PORT=5173
# RUNAPP_AUTO_SITE=1
# RUNAPP_OPEN_SITE_BROWSER=1

# -----------------------------------------------------------------------------
# Database (Docker Compose + SQLx)
# Postgres único (serviço `postgres`, porta 5432): databases apicash, banco_saczuck, dubai-cash.
# Credenciais padrão alinhadas com docker-compose (postgres service).
# -----------------------------------------------------------------------------
POSTGRES_USER=apicash
POSTGRES_PASSWORD=apicash
POSTGRES_DB=apicash
POSTGRES_PORT=5432
DATABASE_URL=postgresql://apicash:apicash@127.0.0.1:5432/apicash
DATABASE_MAX_CONNECTIONS=10
# Custódia no apicash-core: 1 + migrações (`sqlx migrate run`) + Postgres a correr. Sem isto, custódia fica em memória.
APICASH_CUSTODY_PG=1
# Pedidos no apicash-core: 1 + migrações + Postgres a correr. Sem isto, pedidos ficam em memória.
APICASH_ORDERS_PG=1
# Scores/antifraude no apicash-core/admin: 1 + migrações + Postgres a correr. Sem isto, scores ficam em memória.
APICASH_SCORES_PG=1
# Admin lê pedidos/custódia/disputas/scores do Postgres quando 1.
APICASH_ADMIN_PG=1

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0

# -----------------------------------------------------------------------------
# Mensageria — NATS JetStream (padrão local) ou Apache Pulsar (produção futura)
#
# NATS JetStream: ~50 MB RAM, Go binary, inicia em segundos — padrão para dev e SaveInCloud.
# Para ativar NATS: defina NATS_URL e use MESSAGING_BACKEND=nats (Gatebox) + deixe
# APICASH_PULSAR__SERVICE_URL vazio (APICash detecta NATS_URL automaticamente).
#
# Apache Pulsar: JVM, 2 GB RAM — use quando precisar de tópicos multi-tenant em produção.
# Para ativar Pulsar: defina APICASH_PULSAR__SERVICE_URL e use MESSAGING_BACKEND=pulsar.
# Descomente o serviço `pulsar` no docker-compose.yml.
# -----------------------------------------------------------------------------

# NATS JetStream
NATS_URL=nats://127.0.0.1:4222
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# Apache Pulsar (desativado por padrão — descomente + ative serviço no compose se necessário)
# APICASH_PULSAR__SERVICE_URL=pulsar://127.0.0.1:6650
PULSAR_URL=pulsar://127.0.0.1:6650
PULSAR_BROKER_PORT=6650
PULSAR_ADMIN_PORT=8080
PULSAR_SERVICE_URL=pulsar://127.0.0.1:6650
PULSAR_ADMIN_URL=http://127.0.0.1:8080
PULSAR_TENANT=apicash
PULSAR_NAMESPACE=default

# -----------------------------------------------------------------------------
# Stellar / Anchor
# -----------------------------------------------------------------------------
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_ANCHOR_URL=https://anchor.example.com
STELLAR_ANCHOR_SEP10_JWT_SECRET=change-me
STELLAR_SIGNING_SEED=change-me
# Nomes usados no código Rust (apicash-core / anchor)
APICASH_STELLAR_NETWORK=testnet
APICASH_STELLAR_ANCHOR_URL=https://anchor.example.com
# `simulated` | `mock` = sem Anchor HTTP; com `GATEBOX_BASE_URL` o âncora chama o Gatebox (BR Code real). `APICASH_GATEBOX_ENABLED=0` desliga. `anchor` = HTTP ao SEP/Âncora.
APICASH_FIAT_RAIL=simulated
# Opcional: 0 = força mock mesmo com GATEBOX_BASE_URL. Omitir = usa Gatebox se URL estiver definida.
APICASH_GATEBOX_ENABLED=1

# --- Cliente HTTP apicash-anchor → Gatebox (obrigatório para B: QR + copia-e-cola EMV)
# URL = mesma API Rust que ./runapp.sh sobe (GB_API_PORT). Sem isto / sem Gatebox a correr → fallback mock.
GATEBOX_BASE_URL=http://127.0.0.1:8081
# GATEBOX_API_KEY=          # opcional: Bearer no POST /api/v1/pix/qrcode (vazio = sem header)
GATEBOX_CUSTOMER_NAME="Comprador HoldFy"
# CPF 11 dígitos (sandbox); alinhar com fluxo de risco / Sulcred em produção
GATEBOX_CUSTOMER_DOCUMENT=12345678909
GATEBOX_DEFAULT_PIX_KEY=test@simulator.com
GATEBOX_TIMEOUT_MS=15000
GATEBOX_QR_EXPIRATION_SECONDS=1800
# Segredo HMAC para verificar webhooks do Gatebox (X-Webhook-Signature).
# Deve coincidir com o `api_key` configurado no webhook_manager do Gatebox.
# Omitir em dev apenas; obrigatório em produção.
# GATEBOX_WEBHOOK_SECRET=
APICASH_STELLAR_ASSET_CODE=BRLx
APICASH_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
APICASH_STELLAR_SECRET_KEY=SANDBOX_DO_NOT_USE_REAL_SECRET

# Obrigatório: transações Stellar/Soroban reais na testnet pública (explorador). PIX continua via Gatebox sandbox.
# Desactivar só para dev offline: APICASH_REQUIRE_TESTNET=0
APICASH_REQUIRE_TESTNET=1

# Soroban testnet (custódia on-chain via Stellar CLI). Secrets reais de testnet: no seu `.env` (não commitar).
APICASH_SOROBAN_ENABLED=1
APICASH_SOROBAN_STRICT=1
APICASH_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
APICASH_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
APICASH_STELLAR_CLI_BIN=stellar
APICASH_SOROBAN_SOURCE_SECRET=
APICASH_SOROBAN_BUYER_SOURCE=
APICASH_SOROBAN_DISPUTE_SOURCE=
APICASH_SOROBAN_WASM_PATH=target/wasm32v1-none/release/apicash_soroban_contracts.wasm
APICASH_SOROBAN_ESCROW_CONTRACT_ID=
APICASH_SOROBAN_ADMIN_ADDRESS=
APICASH_SOROBAN_PLATFORM_ADDRESS=
APICASH_STELLAR_BUYER_ADDRESS=
APICASH_STELLAR_SELLER_ADDRESS=
APICASH_BRLX_TOKEN_CONTRACT_ID=

# Emissor BRLx (obrigatório em mainnet, opcional em testnet com contas pré-fundadas).
# O issuer chama `stellar contract invoke -- transfer` para cunhar BRLx antes de cada depósito.
# Em testnet: deixar vazio se as contas forem pré-fundadas por bootstrap-testnet-env.sh.
# Em mainnet: preencher após bootstrap-mainnet-env.sh (mesmo endereço que o deployer/holdfy-main-deployer).
APICASH_STELLAR_ISSUER_SECRET=
APICASH_STELLAR_ISSUER_ADDRESS=

# --- Mainnet (alternar com bloco testnet acima) ---
# Para usar mainnet: execute scripts/bootstrap-mainnet-env.sh e scripts/soroban-mainnet-deploy.sh
# Os valores abaixo ficam vazios aqui; o bootstrap preenche money/.env.
# APICASH_STELLAR_NETWORK=mainnet
# APICASH_STELLAR_HORIZON_URL=https://horizon.stellar.org
# APICASH_SOROBAN_RPC_URL=https://rpc.stellar.org
# APICASH_STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
# APICASH_REQUIRE_TESTNET=0

# -----------------------------------------------------------------------------
# x402 — pagamento HTTP (Base Sepolia USDC) para rotas protegidas sem JWT
# O fluxo WhatsApp usa JWT + /internal/* (isento). Escrow/PIX continua em Stellar.
# Desactivar em dev offline: APICASH_X402_REQUIRED=0
# -----------------------------------------------------------------------------
APICASH_X402_REQUIRED=0
X402_FACILITATOR_URL=https://facilitator.x402.rs
X402_NETWORK=base-sepolia
# Treasury EVM na Base Sepolia (fundir ETH + USDC testnet para smoke manual)
X402_PAY_TO=
X402_PRICE_USDC=0.01
APICASH_PUBLIC_BASE_URL=http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Fiat rail — evitar duplicar APICASH_FIAT_RAIL (vários `=` fazem prevalecer o ÚLTIMO no .env).
# Valor efectivo está na secção Stellar (~`APICASH_STELLAR_*`). Produção: `anchor` + URL real.
# Contrato HTTP: apicash/docs/anchor-http-contract.md
# -----------------------------------------------------------------------------
# Poller de reconciliação no core (ordens pending_funding).
APICASH_FUNDING_POLLER=
# Janela de expiração para pending_funding (default 30).
APICASH_FUNDING_EXPIRY_MINUTES=30

# -----------------------------------------------------------------------------
# WhatsApp — Cloud API (Meta) e/ou agente multi-device (whatsapp-rust)
# -----------------------------------------------------------------------------
# URL do apicash-core (o agente chama a API). ../runapp.sh define por defeito
# http://127.0.0.1:$APICASH_HTTP_PORT se não estiver definido.
APICASH_CORE_URL=http://127.0.0.1:3000
# Transporte: rust (defeito, multi-device), cloud, both
APICASH_WA_TRANSPORT=rust
# Health / webhook Cloud: 3010 evita conflito com Pulsar (8080)
APICASH_WA_WEBHOOK_BIND=0.0.0.0:3010
# Sessão SQLite do multi-device (defeito em ../runapp.sh: file:<apicash>/.runapp/apicash_whatsapp.db)
APICASH_WA_SQLITE_PATH=
# QR de pareamento: PNG + prévia Unicode no log (INFO). runapp.sh: defeito $(dirname money)/whatsapp_qrcode/whatsapp-pairing-qr.png
# WA_QR_DIR=/caminho/personalizado
# APICASH_WA_QR_PNG=/caminho/whatsapp-pairing-qr.png
# Prévia do mesmo QR em arte Unicode no log (INFO; defeito ligado). APICASH_WA_QR_LOG_UNICODE=0 para desativar.
# runapp.sh abre file://…/whatsapp_qrcode/pair.html no browser (atualiza o PNG a cada 3s). Desligar: APICASH_WA_OPEN_BROWSER=0
# APICASH_WA_OPEN_BROWSER=1
# Opcional: emparelhar com código — só dígitos, E.164 sem +
# APICASH_WA_PAIR_PHONE=
# APICASH_WA_PAIR_CODE=
# Nome em Aparelhos ligados (substitui o "rust" da biblioteca). Também usado como push_name se vazio.
APICASH_WA_DEVICE_LABEL=HoldFy
# APICASH_WA_PUSH_NAME=HoldFy
# Consulta CPF/CNPJ na Receita (portal NFS-e) ao informar documento no chat HoldFy.
# Inscrição = CNPJ do emissor NFS-e (pode ser com máscara). Reinicie apicash-whatsapp após alterar.
NFSE_INSCRICAO=
NFSE_SENHA=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_BUSINESS_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
# UUID do utilizador "seller" (login) — ver auth; ou deixe vazio para UUID nulo em dev.
APICASH_DEFAULT_SELLER_ID=416c05c7-5e75-535b-8cbd-15a3fa9d2876

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-use-long-random-string-in-production
JWT_ISSUER=apicash
JWT_AUDIENCE=apicash-api
APICASH_JWT_SECRET=change-me-use-long-random-string-in-production
APICASH_JWT_ISSUER=apicash
APICASH_JWT_TTL_SECS=3600
APICASH_JWT_REFRESH_TTL_SECS=604800
# Aspas necessárias: parsers .env tratam `;` como separador de variáveis sem aspas.
APICASH_AUTH_USERS="admin:admin:admin;seller:seller:seller;buyer:buyer:buyer"
APICASH_API_KEY=change-me-service-key
APICASH_AUTH_DISABLED=0
APICASH_ADMIN_API_KEY=change-me-admin-key

# -----------------------------------------------------------------------------
# URLs serviços APICash
# -----------------------------------------------------------------------------
PUBLIC_APP_URL=http://127.0.0.1:3000
ADMIN_API_URL=http://127.0.0.1:3001
APICASH_HTTP_PORT=3000
APICASH_HTTP_BIND=0.0.0.0:3000
APICASH_ADMIN_API_URL=http://127.0.0.1:3001

# -----------------------------------------------------------------------------
# Docker Compose — pgAdmin (profile: tools)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@apicash.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# -----------------------------------------------------------------------------
# Outros (antifraude, notificações, CLI)
# -----------------------------------------------------------------------------
SEFAZ_API_URL=
SEFAZ_CLIENT_ID=
SEFAZ_CLIENT_SECRET=
# Bearer token para o provider SEFAZ (FiscalAPI etc). Alternativa a SEFAZ_CLIENT_SECRET.
SEFAZ_API_TOKEN=
# Modo de validação de CPF: "local" (dígitos verificadores, sem HTTP) | "mock" (padrão) | "http" (usa SEFAZ_API_URL)
SEFAZ_PROVIDER=local
SOCIAL_SCORE_API_KEY=
# Habilita HEAD request real para verificar presença de perfil social (0=mock, 1=real)
SOCIAL_CHECK_ENABLED=0
# Persiste cache de CPF/CNPJ validados no Postgres (requer DATABASE_URL + migration)
APICASH_DOC_CACHE_PG=1
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMS_PROVIDER_API_KEY=
APICASH_HTTP_BASE=http://127.0.0.1:3000
APICASH_BEARER_TOKEN=
APICASH_ADMIN_HTTP_BASE=http://127.0.0.1:3001
APICASH_STELLAR_TEST_ACCOUNT=

# -----------------------------------------------------------------------------
# Banco Saczuck — API Go (gatebox/banco/backend_banco)
# Arranque: ./runapp.sh (scope banco ou all). Base criada por ./runinfra.sh no Postgres APICash.
# -----------------------------------------------------------------------------
BANCO_HTTP_ADDR=:8091
BANCO_POSTGRES_DB=banco_saczuck
# Por defeito alinha com POSTGRES_* acima (sobrescreva se usar outro host/porta).
BANCO_DATABASE_URL=postgresql://apicash:apicash@127.0.0.1:5432/banco_saczuck?sslmode=disable
BANCO_JWT_SECRET=change-me-banco-jwt
BANCO_ENVIRONMENT=sandbox
BANCO_WEBHOOK_URL=http://127.0.0.1:8081/internal/bank/webhooks
BANCO_DEFAULT_SIM_BEHAVIOR=manual
# Chave/API do Gatebox consumida pelo backend banco (sandbox)
GATEBOX_API_KEY=sandbox-key

# =============================================================================
# Gatebox Rust (gatebox/gatebox-rust) — valores adicionais ao bloco APICash acima.
# O mesmo ficheiro money/.env pode ser ligado a gatebox/gatebox-rust/.env via setup-env.sh.
# =============================================================================

SERVICE_NAME=gatebox-rust
SERVICE_VERSION=1.0.0

# HTTP da API Rust (money/runapp.sh exporta GB_API_PORT → PORT no processo gatebox-rust).
# Deve coincidir com o host/porta de GATEBOX_BASE_URL na secção APICash acima.
GB_API_PORT=8081
# GATEBOX_BASE_URL já definido acima (âncora). Não duplicar com URL diferente.
# Opcional — override quando gatebox não está em money/../gatebox (ver runinfra/runapp).
# GATEBOX_RUST_DIR=/home/devel/git/pos-nearx/gatebox/gatebox-rust

# Compose money: Postgres único (5432). Database Gatebox: dubai-cash (mesmas credenciais POSTGRES_*).
GATEBOX_POSTGRES_DB=dubai-cash

POSTGRESQL_WRITE_URL=postgres://apicash:apicash@127.0.0.1:5432/dubai-cash?sslmode=disable
POSTGRESQL_READ_URL=postgres://apicash:apicash@127.0.0.1:5432/dubai-cash?sslmode=disable

# Mensageria: usa o mesmo `PULSAR_URL` / `PULSAR_BROKER_PORT` que o bloco Apache Pulsar acima (defeito 6650).
# Só defina `GATEBOX_PULSAR_CLIENT_URL` se tiver um broker à parte (não é o caso no compose money actual).
# GATEBOX_PULSAR_CLIENT_URL=

# Mensageria **interna** do processo Gatebox só (o APICash ignora esta chave).
# Valores: nats | pulsar | sync (padrão: sync para dev local sem filas)
# - nats: NATS JetStream (~50 MB RAM) — use no SaveInCloud e em ambientes sem Pulsar
# - pulsar: Apache Pulsar (2 GB RAM) — produção futura com alto volume de mensagens
# - sync: processamento síncrono direto — sem fila, sem broker, mais simples para dev
MESSAGING_BACKEND=nats

EXPLORER_BASE_URL=https://polygonscan.com

# --- Gatebox (gatebox-rust): escolha do gateway PIX e URLs a jusante
# Estas chaves são lidas **só pelo processo Gatebox**, não pelo runapp.sh. O APICash fala apenas com
# GATEBOX_BASE_URL; Quem chama Sulcred/SevenTrust/Next é o Gatebox conforme a sua configuração.
# Documentação / simuladores: repositório gatebox (ex. simulador_rust/sulcred em dev, manualmente).
# =============================================================================
# BlindPay — âncora PIX ↔ Stellar (gateway PIX PRINCIPAL do Gatebox)
# Docs: https://www.blindpay.com/docs
# Dashboard: https://app.blindpay.com
# Em dev: PIX não passa pelos trilhos reais; stablecoin = USDB na Stellar testnet.
# =============================================================================
PIX_GATEWAY_BLINDPAY=1
BLINDPAY_BASE_URL=https://api.blindpay.com
BLINDPAY_INSTANCE_ID=in_34NvPJWRqFzn
BLINDPAY_API_KEY=
# ID da blockchain wallet criada no BlindPay (aba blockchain-wallets no dashboard)
BLINDPAY_WALLET_ID=
# Stellar secret seed para assinar XDR no payout (PIX OUT para vendedor)
BLINDPAY_STELLAR_SECRET=
BLINDPAY_STELLAR_NETWORK=testnet
# Customer e bank-account pré-cadastrados para payout (PIX OUT)
BLINDPAY_PAYOUT_CUSTOMER_ID=
BLINDPAY_PAYOUT_BANK_ACCOUNT_ID=
# Customer para payin (opcional — vazio = QR anônimo)
BLINDPAY_PAYIN_CUSTOMER_ID=

# --- Simuladores (desativados por padrão — descomentar para usar sem BlindPay)
# PIX_GATEWAY_SULCRED=1
SULCRED_CLIENT_ID=sandbox-client
SULCRED_CLIENT_SECRET=sandbox-secret
SULCRED_OUT_URL=http://127.0.0.1:7020

# Curl smoke (opcional jq): `./scripts/smoke-gatebox-pix.sh`
# Ou manualmente:
#   curl -sS http://127.0.0.1:${GB_API_PORT:-8081}/api/v1/pix/qrcode -H 'Content-Type: application/json' \
#     -d '{"amount":10.5,"payer_name":"T","payer_document":"12345678909","description":"x","expiration_seconds":600,"reference":"r1","pix_key":"test@simulator.com"}'

# --- MinIO (object storage para imagens importadas de anúncios)
# Console web: http://localhost:9001 (usuário/senha abaixo)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=holdfy
MINIO_SECRET_KEY=holdfy123
MINIO_BUCKET=holdfy-images

# --- MongoDB (conversas WhatsApp + resumos para disputas)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=apicash_wa

# --- OpenAI (extração de produtos via LLM + resumos de conversas WhatsApp)
# Fallback do importer quando JSON-LD/OpenGraph/MercadoLivre não extraem dados.
# Também usado para gerar resumos de conversa (disputas).
OPENAI_API_KEY=sk-...
# Modelo padrão: gpt-4o-mini (barato e rápido para extração/resumo)
# Outras opções: gpt-4o, gpt-4-turbo
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Logística / rastreio (apicash-logistics)
# Modo simulado: consulta o backend LogisticaHoldFy (holdy/apprastreio/backend :8092).
# Crie códigos no app Flutter LogisticaHoldFy e consulte via WhatsApp, site ou GET /logistics/tracking/{code}.
# Produção: APICASH_TRACKING_MODE=live + tokens Correios/LinkTrack/Melhor Envio.
# -----------------------------------------------------------------------------
APICASH_TRACKING_MODE=simulated
APICASH_TRACKING_SIMULATOR_URL=http://127.0.0.1:8092
LOGISTICA_HTTP_PORT=8092
LOGISTICA_WHATSAPP_NOTIFY_URL=http://127.0.0.1:3010/internal/tracking-step-notify
# APICASH_API_KEY já definido acima — usado pelo backend logística para notify WhatsApp
# MELHOR_ENVIO_TOKEN=
# MELHOR_ENVIO_SANDBOX=1
# CORREIOS_USER=
# CORREIOS_ACCESS_CODE=
# LINKETRACK_USER=
# LINKETRACK_TOKEN=

# -----------------------------------------------------------------------------
# Login Social OAuth 2.0
# Cada provedor requer cadastro externo + segredos. Deixar vazios desativa o provedor.
# OAUTH_REDIRECT_BASE_URL: URL pública do backend Core (sem barra final)
# FRONTEND_URL: URL pública do site React (sem barra final)
# -----------------------------------------------------------------------------
OAUTH_REDIRECT_BASE_URL=http://127.0.0.1:3000
FRONTEND_URL=http://127.0.0.1:5173

# Google (console.cloud.google.com → APIs & Services → OAuth 2.0 Client IDs)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx

# Facebook (developers.facebook.com → Meu App → Configurações → Básico)
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# LinkedIn (linkedin.com/developers/apps → Auth → OAuth 2.0)
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Apple (developer.apple.com → Certificates → Services ID → Sign in with Apple)
# APPLE_CLIENT_ID=com.holdfy.webapp
# APPLE_TEAM_ID=XXXXXXXXXX
# APPLE_KEY_ID=XXXXXXXXXX
# APPLE_PRIVATE_KEY_P8=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
