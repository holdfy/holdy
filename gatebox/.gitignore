# ============================================
# Gatebox - .gitignore unificado (todos os projetos)
# ============================================

# --- Binários e executáveis ---
*.exe
*.exe~
*.dll
*.so
*.dylib
main
/bin/
**/bin/
gateboxgo_debug
teste_build/
**/*_debug
*.a
*.o

# --- Go ---
*.test
*.out
go.work
vendor/
**/vendor/

# --- Node / JavaScript / Frontend ---
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
.pnp.*
dist/
build/
**/dist/
**/build/
.next/
out/
.nuxt/
.cache/
.parcel-cache/
*.tsbuildinfo

# --- Rust ---
target/
**/target/

# --- Logs ---
*.log
**/*.log
app.log
api.log
*.log.*

# --- Variáveis de ambiente e secrets ---
.env
.env.*
!.env.example
!.env.*.example
config.env
*.env.local
.env.production
.env.development.local
.env.test.local
.env.production.local

# --- Certificados e chaves (sensíveis - não versionar) ---
*.pfx
*.key
*.crt
*.csr
*.pem
*.cer
*.p12
*.jks
certificados/
**/certificados/**/*.pfx
**/certificados/**/*.key
**/certificados/**/*.crt
**/certificados/**/*.csr
**/certificados/**/*.pem
**/certificados/**/*.cer

# --- IDEs e editores ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# --- Sistema operacional ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Temporários e caches ---
tmp/
temp/
**/tmp/
**/temp/
*.tmp
*.temp
.cache/

# --- Docker (overrides locais) ---
docker-compose.override.yml
docker-compose.*.local.yml

# --- Gatebox Rust (arquivos locais de apoio/anotações) ---
gatebox-rust/conversa_gpt
gatebox-rust/importante.txt
gatebox-rust/importante*.txt

# --- Dados e volumes locais ---
**/test-chain*/
**/validator*-data/
*.sqlite
*.db

# --- Outros ---
*.bak
*.backup
coverage/
.nyc_output/
*.lcov
