# Gatebox Rust - variáveis de ambiente (copie para .env e ajuste)
# Servidor
PORT=8081
SERVICE_NAME=gatebox-rust
SERVICE_VERSION=1.0.0

# Métricas Prometheus (porta 2112 dedicada, como no Go)
ENABLE_METRICS=true
METRICS_PORT=2112

# Banco de dados (mesmo schema que gateboxgo)
POSTGRESQL_WRITE_URL=postgres://apicash:apicash@localhost:5432/dubai-cash?sslmode=disable
POSTGRESQL_READ_URL=postgres://apicash:apicash@localhost:5432/dubai-cash?sslmode=disable

# Autenticação JWT
JWT_SECRET=default-secret-change-in-production

# Redis (opcional; se não definir REDIS_ENABLED=false, usa REDIS_URL)
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=true

# RabbitMQ (opcional; se definido, inicia WorkerPool com PaymentMessageHandler)
# Mensageria: Pulsar (principal) ou RabbitMQ
# MESSAGING_BACKEND=pulsar (default) ou rabbitmq
# Para Pulsar: PULSAR_URL alinhado com `money/` (um único broker para APICash + Gatebox, defeito porta 6650).
PULSAR_URL=pulsar://127.0.0.1:6650
# RBMQ_URI=amqp://adminUser:strongPassword@localhost:5673

# =============================================================================
# Gateways PIX — BlindPay é o principal. Os demais ficam como fallback/simuladores.
# Para trocar: comente PIX_GATEWAY_BLINDPAY e descomente outro.
# =============================================================================

# BlindPay (PRINCIPAL — âncora PIX ↔ Stellar)
PIX_GATEWAY_BLINDPAY=1
BLINDPAY_BASE_URL=https://api.blindpay.com
BLINDPAY_INSTANCE_ID=in_34NvPJWRqFzn
BLINDPAY_API_KEY=
# ID da carteira Stellar criada no BlindPay dashboard (blockchain-wallets)
BLINDPAY_WALLET_ID=
# Stellar secret seed para assinar XDR no payout (PIX OUT). Dev: conta testnet.
BLINDPAY_STELLAR_SECRET=
BLINDPAY_STELLAR_NETWORK=testnet
# Customer e bank account pré-cadastrados no BlindPay para payout (PIX OUT)
BLINDPAY_PAYOUT_CUSTOMER_ID=
BLINDPAY_PAYOUT_BANK_ACCOUNT_ID=
# Customer para payin (opcional — gera QR para comprador anônimo se vazio)
BLINDPAY_PAYIN_CUSTOMER_ID=

# Sulcred (simulador — desativado por padrão, manter para fallback)
# PIX_GATEWAY_SULCRED=1
SULCRED_CLIENT_ID=
SULCRED_CLIENT_SECRET=
SULCRED_OUT_URL=http://localhost:7020

# SevenTrust (simulador — desativado por padrão)
# PIX_GATEWAY_SEVENTRUST=1
SEVENTRUST_CLIENT_ID=
SEVENTRUST_CLIENT_SECRET=
SEVENOUT_URL=http://localhost:7010

# Next (simulador — desativado por padrão)
# PIX_GATEWAY_NEXT=1
NEXT_CLIENT_ID=
NEXT_CLIENT_SECRET=

# PULSAR_TENANT=public
# PULSAR_NAMESPACE=default

# Anchor / blockchain
EXPLORER_BASE_URL=https://polygonscan.com
